# ============================================
# droid-chat-channel 配置文件
# 复制为 .env 后填写你的配置
# cp .env.example .env
# ============================================

# ---- 必填 ----

# 平台选择: telegram | whatsapp
PLATFORM=telegram

# Telegram Bot Token (从 @BotFather 获取)
TELEGRAM_BOT_TOKEN=

# WhatsApp 无需 Token，首次启动扫码即可

# ---- 可选 ----

# 允许的用户 (逗号分隔)
# Telegram: 用户 ID (从 @userinfobot 获取)
# WhatsApp: 手机号 (如 8613800138000)
ALLOWED_USERS=

# Droid CLI 路径 (默认: droid)
DROID_PATH=droid

# 默认模型 (默认: custom:minimax-m2.7)
DROID_MODEL=custom:minimax-m2.7

# 超时秒数 (默认: 120)
DROID_TIMEOUT=120

# 数据目录 (默认: ./data)
DATA_DIR=./data

# ---- 上下文路由 (可选) ----
# JSON 格式，定义群聊到工作目录的映射
# 示例:
# CONTEXT_MAP={"groups":{"-123456":{"cwd":"/home/user/family","label":"Family"}},"private":{"cwd":"/home/user/workspace","label":"Work"}}
CONTEXT_MAP=

# ---- API Keys (用于 Droid custom models) ----
# 如果你使用 custom model，需要配置对应 API Key
# 这些 key 也要配在 systemd service 或 .env 中

# MiniMax
MINIMAX_API_KEY=

# 智谱 (GLM)
ZAI_API_KEY=

# 讯飞
XFYUN_API_KEY=
